DATABASE_URL=postgres://postgres:postgres@localhost:5432/aimmod_hub?sslmode=disable
AIMMOD_HUB_ADDR=:8080
AIMMOD_HUB_VERSION=dev
AIMMOD_HUB_WEB_ORIGIN=http://localhost:5173
AIMMOD_HUB_API_BASE_URL=http://localhost:8080
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/auth/discord/callback
AIMMOD_HUB_ADMIN_DISCORD_USER_ID=
SESSION_COOKIE_SECURE=false
# Set to web/dist to serve the frontend from the API with SSR meta injection (Mode B).
# Leave unset to serve the frontend via Nginx separately (Mode A).
AIMMOD_HUB_STATIC_DIR=
VITE_API_BASE_URL=http://localhost:8080
AIMMOD_HUB_MEDIA_BACKEND=local
AIMMOD_HUB_MEDIA_DIR=./var/media
AIMMOD_HUB_S3_BUCKET=
AIMMOD_HUB_S3_REGION=auto
AIMMOD_HUB_S3_ENDPOINT=
AIMMOD_HUB_S3_ACCESS_KEY_ID=
AIMMOD_HUB_S3_SECRET_ACCESS_KEY=
AIMMOD_HUB_S3_FORCE_PATH_STYLE=false
