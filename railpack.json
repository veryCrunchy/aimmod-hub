{
  "$schema": "https://schema.railpack.com",
  "provider": "go",
  "steps": {
    "build": {
      "inputs": [
        {
          "local": true
        }
      ],
      "commands": [
        "go build -o bin/aimmod-hub ./api/cmd/aimmod-hub"
      ],
      "deployOutputs": [
        {
          "include": [
            "bin/aimmod-hub"
          ]
        }
      ]
    }
  },
  "deploy": {
    "startCommand": "./bin/aimmod-hub"
  }
}